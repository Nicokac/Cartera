{
  "horizon_days": 5,
  "direction_threshold": 0.15,
  "active_vote_threshold": 0.1,
  "neutral_return_band": 0.01,
  "calibration": {
    "min_samples": 30,
    "min_weight": 0.1,
    "max_weight": 1.0,
    "lookback_samples": 60,
    "min_recent_samples": 20
  },
  "signals": {
    "rsi": {
      "weight": 0.8,
      "vote_mode": "continuous",
      "vote_rules": {
        "center": 50.0,
        "lower_bound": 0.0,
        "upper_bound": 100.0
      }
    },
    "momentum_20d": {
      "weight": 0.6,
      "vote_mode": "continuous",
      "vote_rules": {
        "positive_threshold": 2.0,
        "negative_threshold": -2.0,
        "positive_saturation": 8.0,
        "negative_saturation": 8.0
      }
    },
    "momentum_60d": {
      "weight": 0.5,
      "vote_mode": "continuous",
      "vote_rules": {
        "positive_threshold": 5.0,
        "negative_threshold": -5.0,
        "positive_saturation": 15.0,
        "negative_saturation": 15.0
      }
    },
    "sma_trend": {
      "weight": 0.4,
      "vote_rules": {
        "bullish_values": [
          "Alcista",
          "Alcista fuerte"
        ],
        "bearish_values": [
          "Bajista",
          "Bajista fuerte"
        ]
      }
    },
    "score_unificado": {
      "weight": 0.7,
      "vote_mode": "continuous",
      "vote_rules": {
        "high_threshold": 0.1,
        "low_threshold": -0.1,
        "positive_saturation": 0.4,
        "negative_saturation": 0.4
      }
    },
    "market_regime": {
      "weight": 0.5,
      "vote_rules": {
        "bearish_flags": [
          "stress_soberano_local",
          "tasas_ust_altas"
        ],
        "bullish_when_no_flags": true,
        "flag_effects": {
          "inflacion_local_alta": {
            "bond_cer": 0,
            "stock_argentina": -1,
            "default": 0
          }
        }
      }
    },
    "adx": {
      "weight": 0.3,
      "vote_mode": "continuous",
      "vote_rules": {
        "adx_threshold": 20.0,
        "adx_saturation": 45.0
      }
    },
    "relative_volume": {
      "weight": 0.3,
      "vote_rules": {
        "high_threshold": 1.5
      }
    }
  }
}
