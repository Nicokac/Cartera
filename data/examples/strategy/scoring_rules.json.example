  },
  "market_regime": {
    "enabled": true,
    "flags": {
      "inflacion_local_alta": {
        "rem_inflacion_mensual_pct_min": 3.0
      }
    }
  },
  "asset_subfamily_adjustments": {
    "stock_growth": {
      "refuerzo_penalty": 0.03,
      "reduccion_boost": 0.02
    },
    "stock_commodity": {
      "technical_mixed_refuerzo_penalty": 0.01,
