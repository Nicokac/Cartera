{
  "absolute_scoring": {
    "enabled": true,
    "relative_weight": 0.9,
    "absolute_weight": 0.1
  },
  "technical_overlay": {
    "enabled": true,
    "history_period": "18mo",
    "interval": "1d",
    "blend_base": 0.75,
    "blend_tech": 0.25,
    "ranges": {
      "dist_sma200_pct": {
        "min": -25.0,
        "max": 25.0
      }
    },
    "subscores": {
      "above_sma200": 0.05
    },
    "reduction_subscores": {
      "below_sma200": 0.05
